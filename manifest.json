{
  "manifest_version": 3,
  "name": "IGXE Price Helper",
  "version": "1.0.4",
  "description": "在饰品库存页和我的在架页显示Steam参考价和自动发货最低价",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.igxe.cn/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.igxe.cn/inventory/skins/*"],
      "js": ["content-inventory.js"],
      "css": ["injected.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.igxe.cn/sell/*"],
      "js": ["content-sell.js"],
      "css": ["injected.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "IGXE Price Helper"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
