{
  "manifest_version": 3,
  "name": "IGXE Price Helper",
  "version": "1.0.8",
  "description": "IGXE 饰品辅助工具：自动显示 Steam 参考价和自动发货最低价，支持已在售物品标记、搜索按钮、贩卖总数差值、改价计时器等实用功能",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.igxe.cn/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.igxe.cn/inventory/skins/*"],
      "js": ["content-shared.js", "content-inventory.js"],
      "css": ["injected.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.igxe.cn/sell/*"],
      "js": ["content-shared.js", "content-sell.js"],
      "css": ["injected.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "IGXE Price Helper"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
